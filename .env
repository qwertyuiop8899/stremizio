# Stremizio 2.0 - Environment Variables

# TMDB API Key (Required)
# Get your key from: https://www.themoviedb.org/settings/api
TMDB_KEY=your_tmdb_api_key_here

# Real-Debrid API Key (Optional)
# Get your key from: https://real-debrid.com/apitoken
RD_KEY=your_realdebrid_api_key_here

# MediaFlow Proxy (Optional - for RD sharing)
# Allows sharing Real-Debrid with multiple users by masking IPs
# Get your instance from: https://github.com/mhdzumair/mediaflow-proxy
MEDIAFLOW_URL=https://your-mediaflow-instance.com
MEDIAFLOW_PASSWORD=your_mediaflow_password_here

# Torbox API Key (Optional)
# Get your key from: https://torbox.app/settings
TORBOX_KEY=your_torbox_api_key_here

# Jackettio Configuration (Optional - Private Use)
# Your Jackettio instance URL (NO trailing slash)
JACKETT_URL=https://eschiano-jackett.elfhosted.com

# Your Jackettio API Key
# Get it from: Jackettio Dashboard > API Key
JACKETT_API_KEY=your_jackett_api_key_here

# Jackettio Password (OPTIONAL - only if your instance requires authentication)
# Leave empty or don't set if your instance doesn't have password protection
# JACKETT_PASSWORD=your_jackett_password_here
